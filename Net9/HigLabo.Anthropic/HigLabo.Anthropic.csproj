<Project Sdk="Microsoft.NET.Sdk">

	<PropertyGroup>
		<TargetFrameworks>net8.0;net9.0;net10.0</TargetFrameworks>
		<ImplicitUsings>enable</ImplicitUsings>
		<Nullable>enable</Nullable>

		<Version>10.1.0.0</Version>
		<GeneratePackageOnBuild>true</GeneratePackageOnBuild>
		<Company>HigLabo</Company>
		<Authors>Higty</Authors>
		<Copyright>Copyright © 2011- HigLabo All Rights Reserved</Copyright>
		<RepositoryUrl>https://github.com/higty/higlabo</RepositoryUrl>
		<PackageLicenseExpression>MIT</PackageLicenseExpression>
		<GenerateDocumentationFile>true</GenerateDocumentationFile>
		<NoWarn>1591;NETSDK1138</NoWarn>
		
		<Description>
			How to use? See sample code
			https://github.com/higty/higlabo/blob/master/Net9/HigLabo.Anthropic.SampleConsoleApp/AnthropicClientPlayground.cs
		</Description>
		<PackageTags>Anthropic;Claude;</PackageTags>
		<PackageReadmeFile>README.md</PackageReadmeFile>
	</PropertyGroup>

	<ItemGroup>
		<ProjectReference Include="..\HigLabo.Core\HigLabo.Core.csproj" />
		<ProjectReference Include="..\HigLabo.NewtonsoftJson\HigLabo.NewtonsoftJson.csproj" />
	</ItemGroup>

	<ItemGroup>
		<None Include="README.md" Pack="true" PackagePath="\" />
		<None Update="Image\Rock.jpg">
	    <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
	  </None>
	</ItemGroup>

</Project>
